OF_HOST=
OF_PORT=11033

# Do not paste credentials into chat. Put them only in your local copy of this file.
OF_SDK_UID=
OF_LOGIN_TOKEN=
OF_EMAIL=
OF_PASSWORD=
OF_ACCOUNT_LOGIN_URL=

# Optional local paths for refresh_live_env.bat.
# If omitted, the default Steam install path and LocalLow Player.log path are used.
OF_GAME_INSTALL_DIR=C:\Program Files (x86)\Steam\steamapps\common\OverField
OF_QGPC_LOG_PATH=
OF_PLAYER_LOG_PATH=

OF_ACCOUNT_TYPE=0
OF_OS=0
OF_LANGUAGE=4
OF_CHANNEL_CODE=
OF_DEVICE_UUID=codex-overfield-probe

OF_CLIENT_VERSION=
OF_RESOURCE_VERSION=
OF_VERSION_NUMBER=
OF_DEVICE_MODEL=Windows PC
OF_NETWORK=wifi
OF_IP=127.0.0.1
OF_IPV6=
OF_OS_NAME=Windows
OF_OS_VER=10

# Candidate NPC talk ids. Current best guesses from static resources:
# Aya=10001, Azusa=10002, Richard=10004
OF_NPC_TALK_IDS=10001,10002,10004

# Optional publishing target reference for external JSON mirroring
PUBLIC_REPO_OWNER=Vrcticfox
PUBLIC_REPO_NAME=ExternalResources
PUBLIC_REPO_BRANCH=main
PUBLIC_REPO_TARGET_DIR=overfield/gatheredDaily
PUBLIC_REPO_JSON_NAME=live_daily_jobs.json

# Optional GitHub automation for AutoShopGather/refresh_live_env.py.
# GITHUB_SECRETS_PAT needs repository "Secrets: write".
# GITHUB_ACTIONS_PAT or the same token needs repository "Actions: write" if dispatch is enabled.
GITHUB_REPO_OWNER=Vrcticfox
GITHUB_REPO_NAME=Overfield_AutoShopGather
GITHUB_SECRETS_PAT=
GITHUB_ACTIONS_PAT=
GITHUB_SYNC_SECRETS=0
GITHUB_AUTO_DISPATCH=0
GITHUB_WORKFLOW_FILE=daily-jobs-refresh.yml
GITHUB_WORKFLOW_REF=main
GITHUB_WORKFLOW_MODE=watch
